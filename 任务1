import http.client
import ssl
import urllib.parse

def follow_redirects(url, max_redirects=5):
    """Follow HTTP redirects and return the final connection and response."""
    parsed = urllib.parse.urlparse(url)
    host = parsed.hostname
    path = parsed.path or '/'
    if parsed.query:
        path += '?' + parsed.query
    
    context = ssl._create_unverified_context()
    
    for _ in range(max_redirects):
        conn = http.client.HTTPSConnection(host, 443, context=context, timeout=300)
        conn.request('GET', path)
        response = conn.getresponse()
        
        if response.status in [301, 302, 307, 308]:
            location = response.getheader('Location')
            conn.close()
            
            # Parse the new URL
            new_parsed = urllib.parse.urlparse(location)
            if new_parsed.hostname:
                host = new_parsed.hostname
            path = new_parsed.path or '/'
            if new_parsed.query:
                path += '?' + new_parsed.query
            continue
        else:
            return conn, response
    
    raise Exception(f"Too many redirects (max {max_redirects})")

url = 'https://ollama.com/download/OllamaSetup.exe'
output_file = 'OllamaSetup.exe'

print(f'Downloading {url} to {output_file}...')

try:
    conn, response = follow_redirects(url)
    
    print(f'Status: {response.status} {response.reason}')
    
    if response.status != 200:
        print(f'Failed to download: HTTP {response.status}')
        conn.close()
        exit(1)
    
    total_size = int(response.headers.get('Content-Length', 0))
    print(f'Total size: {total_size:,} bytes')
    
    downloaded_size = 0
    chunk_size = 1024 * 1024  # 1MB chunks
    
    with open(output_file, 'wb') as f:
        while True:
            chunk = response.read(chunk_size)
            if not chunk:
                break
            f.write(chunk)
            downloaded_size += len(chunk)
            progress = (downloaded_size / total_size) * 100
            print(f'\rDownloaded: {downloaded_size:,}/{total_size:,} bytes ({progress:.1f}%)', end='')
    
    conn.close()
    print('\nDownload completed successfully!')
    
except Exception as e:
    print(f'Error: {e}')
    import traceback
    traceback.print_exc()
