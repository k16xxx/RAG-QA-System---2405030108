"""
RAG问答链集成系统
将文档检索与Ollama大模型结合，实现基于文档的智能问答
"""
import os
import glob
import PyPDF2
from docx import Document
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_ollama import ChatOllama, OllamaEmbeddings
from langchain_community.vectorstores import Chroma
from langchain_core.prompts import PromptTemplate
from langchain_core.runnables import RunnablePassthrough
from langchain_core.output_parsers import StrOutputParser
from langchain_core.documents import Document as LangchainDocument

class RAGSystem:
    """完整的RAG问答系统"""
    
    def __init__(self, 
                 document_folder="documents",
                 embedding_model="nomic-embed-text",
                 llm_model="deepseek-r1:7b",
                 chunk_size=1000,
                 chunk_overlap=200):
        """
        初始化RAG系统
        
        Args:
            document_folder: 文档文件夹路径
            embedding_model: 嵌入模型名称
            llm_model: 大语言模型名称
            chunk_size: 文本分块大小
            chunk_overlap: 分块重叠大小
        """
        self.document_folder = document_folder
        self.embedding_model = embedding_model
        self.llm_model = llm_model
        self.chunk_size = chunk_size
        self.chunk_overlap = chunk_overlap
        
        self.vectorstore = None
        self.retriever = None
        self.qa_chain = None
        
    def extract_text_from_pdf(self, pdf_path):
        """从PDF文件中提取文本"""
        text = ""
        try:
            with open(pdf_path, 'rb') as file:
                pdf_reader = PyPDF2.PdfReader(file)
                for page in pdf_reader.pages:
                    text += page.extract_text() + "\n"
        except Exception as e:
            print(f"读取PDF文件 {pdf_path} 时出错: {e}")
        return text
    
    def extract_text_from_docx(self, docx_path):
        """从DOCX文件中提取文本"""
        text = ""
        try:
            doc = Document(docx_path)
            for paragraph in doc.paragraphs:
                text += paragraph.text + "\n"
        except Exception as e:
            print(f"读取DOCX文件 {docx_path} 时出错: {e}")
        return text
    
    def load_documents(self):
        """加载并处理文件夹中的所有文档"""
        print("=" * 60)
        print("步骤1: 加载文档")
        print("=" * 60)
        
        documents = []
        
        # 查找所有PDF和DOCX文件
        files = glob.glob(os.path.join(self.document_folder, "*.pdf")) + \
                glob.glob(os.path.join(self.document_folder, "*.docx"))
        
        if not files:
            print(f"❌ 在 {self.document_folder} 中未找到任何文档")
            return None
        
        print(f"找到 {len(files)} 个文档文件")
        
        for file_path in files:
            filename = os.path.basename(file_path)
            print(f"处理: {filename}")
            
            if file_path.endswith('.pdf'):
                text = self.extract_text_from_pdf(file_path)
            elif file_path.endswith('.docx'):
                text = self.extract_text_from_docx(file_path)
            else:
                continue
            
            if text.strip():
                documents.append(LangchainDocument(
                    page_content=text,
                    metadata={'source': filename}
                ))
                print(f"  ✓ 成功提取文本")
            else:
                print(f"  ✗ 未能提取文本")
        
        print(f"\n成功加载 {len(documents)} 个文档")
        return documents
    
    def split_documents(self, documents):
        """对文档进行分块"""
        print("\n" + "=" * 60)
        print("步骤2: 文本分块")
        print("=" * 60)
        
        text_splitter = RecursiveCharacterTextSplitter(
            chunk_size=self.chunk_size,
            chunk_overlap=self.chunk_overlap,
            length_function=len,
            separators=["\n\n", "\n", "。", "！", "？", "；", "，", " ", ""]
        )
        
        chunks = text_splitter.split_documents(documents)
        print(f"将 {len(documents)} 个文档分成了 {len(chunks)} 个文本块")
        return chunks
    
    def create_vectorstore(self, chunks):
        """创建向量数据库"""
        print("\n" + "=" * 60)
        print("步骤3: 创建向量数据库")
        print("=" * 60)
        
        try:
            embeddings = OllamaEmbeddings(
                model=self.embedding_model,
                base_url="http://localhost:11434"
            )
            
            self.vectorstore = Chroma.from_documents(
                documents=chunks,
                embedding=embeddings,
                persist_directory="./chroma_db"
            )
            
            self.retriever = self.vectorstore.as_retriever(
                search_kwargs={"k": 3}
            )
            
            print("✓ 向量数据库创建成功")
            return True
            
        except Exception as e:
            print(f"✗ 向量数据库创建失败: {e}")
            print("请确保Ollama服务已启动")
            return False
    
    def build_qa_chain(self):
        """构建问答链"""
        print("\n" + "=" * 60)
        print("步骤4: 构建问答链")
        print("=" * 60)
        
        if not self.retriever:
            print("❌ 请先创建向量数据库")
            return False
        
        # 系统提示词：要求基于文档回答
        system_prompt = """
你是一个专业的文档问答助手。请根据提供的参考文档回答用户的问题。

重要规则：
1. 仅使用参考文档中的信息进行回答
2. 如果文档中没有相关信息，请明确回答"文档中未找到相关答案"
3. 不要编造信息或使用外部知识
4. 回答要简洁明了，直接针对问题

参考文档：
{context}

问题：{question}
"""
        
        prompt = PromptTemplate(
            template=system_prompt,
            input_variables=["context", "question"]
        )
        
        try:
            llm = ChatOllama(
                model=self.llm_model,
                base_url="http://localhost:11434",
                temperature=0.1,
                max_tokens=512
            )
            
            # 构建RAG链
            def format_docs(docs):
                return "\n\n".join(doc.page_content for doc in docs)
            
            self.qa_chain = (
                {"context": self.retriever | format_docs, "question": RunnablePassthrough()}
                | prompt
                | llm
                | StrOutputParser()
            )
            
            print("✓ 问答链构建成功")
            return True
            
        except Exception as e:
            print(f"✗ 问答链构建失败: {e}")
            print("请确保Ollama服务已启动并安装了相应的模型")
            return False
    
    def initialize(self):
        """初始化整个系统"""
        # 加载文档
        documents = self.load_documents()
        if not documents:
            return False
        
        # 分块
        chunks = self.split_documents(documents)
        
        # 创建向量数据库
        if not self.create_vectorstore(chunks):
            return False
        
        # 构建问答链
        if not self.build_qa_chain():
            return False
        
        print("\n" + "=" * 60)
        print("✅ RAG系统初始化完成！")
        print("=" * 60)
        return True
    
    def ask(self, question):
        """向系统提问"""
        if not self.qa_chain:
            print("❌ 系统未初始化")
            return None
        
        try:
            answer = self.qa_chain.invoke(question)
            return answer
        except Exception as e:
            print(f"✗ 提问失败: {e}")
            return None

def main():
    """主函数：演示RAG问答系统"""
    print("=" * 60)
    print("RAG问答链集成系统")
    print("=" * 60)
    print("\n正在初始化系统...")
    
    # 创建RAG系统实例
    rag_system = RAGSystem(
        document_folder="documents",
        embedding_model="nomic-embed-text",
        llm_model="deepseek-r1:7b",
        chunk_size=1000,
        chunk_overlap=200
    )
    
    # 初始化系统
    if not rag_system.initialize():
        print("\n❌ 系统初始化失败，请检查Ollama服务状态")
        return
    
    # 测试问答效果
    print("\n" + "=" * 60)
    print("开始测试问答效果")
    print("=" * 60)
    
    # 测试问题列表
    test_questions = [
        # 与文档相关的问题
        {"question": "什么是Transformer模型？", "type": "相关"},
        {"question": "情感分析有哪些主要方法？", "type": "相关"},
        {"question": "命名实体识别的目标是什么？", "type": "相关"},
        {"question": "文本预处理有哪些步骤？", "type": "相关"},
        {"question": "自然语言处理的主要任务有哪些？", "type": "相关"},
        # 与文档无关的问题
        {"question": "2024年奥运会在哪里举办？", "type": "无关"},
        {"question": "今天的天气怎么样？", "type": "无关"}
    ]
    
    # 记录测试结果
    results = []
    
    for i, test_case in enumerate(test_questions, 1):
        question = test_case["question"]
        q_type = test_case["type"]
        
        print(f"\n--- 测试问题 {i} ({q_type}) ---")
        print(f"问题: {question}")
        
        answer = rag_system.ask(question)
        
        if answer:
            print(f"回答: {answer}")
            
            results.append({
                "question": question,
                "type": q_type,
                "answer": answer,
                "quality": evaluate_answer(question, answer, q_type)
            })
        else:
            print("回答: 无响应")
            results.append({
                "question": question,
                "type": q_type,
                "answer": "无响应",
                "quality": "失败"
            })
    
    # 输出测试报告
    print("\n" + "=" * 60)
    print("测试报告")
    print("=" * 60)
    
    related_correct = 0
    unrelated_correct = 0
    related_total = 0
    unrelated_total = 0
    
    for result in results:
        print(f"\n问题: {result['question']}")
        print(f"类型: {result['type']}")
        print(f"回答: {result['answer']}")
        print(f"质量: {result['quality']}")
        
        if result['type'] == "相关":
            related_total += 1
            if result['quality'] == "良好":
                related_correct += 1
        else:
            unrelated_total += 1
            if result['answer'] == "文档中未找到相关答案":
                unrelated_correct += 1
    
    print("\n" + "-" * 60)
    print(f"相关问题: {related_correct}/{related_total} 正确")
    print(f"无关问题: {unrelated_correct}/{unrelated_total} 正确")
    print(f"总正确率: {(related_correct + unrelated_correct) / len(results) * 100:.1f}%")
    
    # 交互式问答
    print("\n" + "=" * 60)
    print("交互式问答模式 (输入 'exit' 退出)")
    print("=" * 60)
    
    while True:
        question = input("\n请输入问题: ")
        if question.lower() == 'exit':
            break
        
        answer = rag_system.ask(question)
        if answer:
            print(f"\n回答: {answer}")
        else:
            print("\n回答失败，请重试")
    
    print("\n感谢使用RAG问答系统！")

def evaluate_answer(question, answer, q_type):
    """评估回答质量"""
    if q_type == "无关":
        if "文档中未找到相关答案" in answer:
            return "良好"
        else:
            return "错误（应返回未找到）"
    else:
        if "文档中未找到相关答案" in answer:
            return "错误（应找到答案）"
        elif len(answer) < 10:
            return "一般（回答过于简短）"
        else:
            return "良好"

if __name__ == "__main__":
    main()
